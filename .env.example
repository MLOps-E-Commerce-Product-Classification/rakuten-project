TOKEN=<TOKEN>
MLFLOW_TRACKING_URI=https://dagshub.com/Mlops2026/rakuten-project.mlflow
MLFLOW_TRACKING_USERNAME=Mlops2026
MLFLOW_TRACKING_PASSWORD=${TOKEN}
MLFLOW_REGISTRY_URI=https://dagshub.com/Mlops2026/rakuten-project.mlflow
BENTO_TAG=latest

DAGSHUB_USER_TOKEN=${TOKEN}
AWS_ACCESS_KEY_ID=${TOKEN}
AWS_SECRET_ACCESS_KEY=${TOKEN}
AWS_ENDPOINT_URL=https://dagshub.com/Mlops2026/rakuten-project.s3

DEVICE=cu121

HF_TOKEN=<get the token from hugginface>

BENTO_USER=user123
BENTO_PASS=password123
BENTO_JWT_SECRET=rakuten_text_service_secret_key_2026

STREAMLIT_ADMIN_PASSWORD=<STREAMLIT_ADMIN_PASSWORD>
STREAMLIT_DEMO_PASSWORD=<STREAMLIT_DEMO_PASSWORD>
STREAMLIT_BASE_URL=http://bentoml:3000
STREAMLIT_API_KEY=your_api_key_here
STREAMLIT_NGINX_USER=your_nginx_user
STREAMLIT_NGINX_PASS=your_nginx_password
STREAMLIT_BENTO_USER=${BENTO_USER}
STREAMLIT_BENTO_PASS=${BENTO_PASS}

# Dockerhub
DOCKER_USERNAME=mlops2026

# set to rakuten-ml if you want to run it locally and for prod use mlops2026
DOCKER_NAMESPACE=rakuten-ml

# Airflow
AIRFLOW_IMAGE_NAME=apache/airflow:2.8.1
AIRFLOW__CORE__FERNET_KEY=dein-fernet-key
AIRFLOW__WEBSERVER__SECRET_KEY=<WEBSERVER_SECRET_KEY>
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres/airflow
AIRFLOW__CELERY__RESULT_BACKEND=db+postgresql://airflow:airflow@postgres/airflow
POSTGRES_USER=airflow
POSTGRES_PASSWORD=<POSTGRES_PASSWORD>
POSTGRES_DB=airflow
AIRFLOW__SMTP__SMTP_USER=de.airflow@gmail.com
AIRFLOW__SMTP__SMTP_PASSWORD=<AIRFLOW__SMTP__SMTP_PASSWORD>
AIRFLOW__SMTP__SMTP_MAIL_FROM=de.airflow@gmail.com
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=<_AIRFLOW_WWW_USER_PASSWORD>

# Github Token, to push as airflow user in airflow dags
# how to get GIT_TOKEN: go to GitHub → Settings → Developer Settings → Personal Access Tokens → Fine-grained tokens and create a token (https://github.com/settings/tokens)
GIT_TOKEN=<YOUR_GHP_TOKEN>
