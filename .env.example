
# ── Streamlit Dashboard ───────────────────────────────────
# API connection
STREAMLIT_BASE_URL=https://rakuten.industry-ai-engineering.com/bentoml
STREAMLIT_API_KEY=your_api_key_here
STREAMLIT_NGINX_USER=your_nginx_user
STREAMLIT_NGINX_PASS=your_nginx_password
STREAMLIT_BENTO_USER=your_bento_user
STREAMLIT_BENTO_PASS=your_bento_password

# Default passwords for admin/demo_user on first start (optional)
# If not set, accounts have no password until set via admin UI
STREAMLIT_ADMIN_PASSWORD=
STREAMLIT_DEMO_PASSWORD=
