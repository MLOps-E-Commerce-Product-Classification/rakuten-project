{
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "panels": [],
      "title": "Hardware Infrastructure (Node Exporter)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "id": 11,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        { "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode='idle'}[5m])) * 100)", "legendFormat": "CPU Load", "refId": "A" }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "bytes" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 1 },
      "id": 12,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        { "expr": "node_memory_MemTotal_bytes - node_memory_MemAvailable_bytes", "legendFormat": "Used RAM", "refId": "A" },
        { "expr": "node_memory_MemTotal_bytes", "legendFormat": "Total RAM", "refId": "B" }
      ],
      "title": "RAM Usage",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "decbytes"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "id": 13,
      "options": {
        "displayLabels": ["percent", "value"],
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "values": ["value", "percent"]
        },
        "pieType": "donut",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        {
          "expr": "sum(node_filesystem_size_bytes{mountpoint=~'^/$|^/home$', fstype!~'tmpfs|overlay'}) - sum(node_filesystem_avail_bytes{mountpoint=~'^/$|^/home$', fstype!~'tmpfs|overlay'})",
          "legendFormat": "Used",
          "refId": "A"
        },
        {
          "expr": "sum(node_filesystem_avail_bytes{mountpoint=~'^/$|^/home$', fstype!~'tmpfs|overlay'})",
          "legendFormat": "Free",
          "refId": "B"
        }
      ],
      "title": "Disk Usage",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "Bps" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 1 },
      "id": 14,
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      },
      "targets": [
        { "expr": "rate(node_disk_read_bytes_total[5m])", "legendFormat": "Read", "refId": "A" },
        { "expr": "rate(node_disk_written_bytes_total[5m])", "legendFormat": "Write", "refId": "B" }
      ],
      "title": "Disk I/O",
      "type": "timeseries"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }, "id": 20, "panels": [], "title": "Traffic", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 201,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [{ "expr": "sum(rate(rakuten_http_requests_total[1m]))", "legendFormat": "req/s", "refId": "A" }],
      "title": "Requests/sec (BentoML)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 12, "y": 10 },
      "id": 202,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum(rate(rakuten_http_requests_total[5m])) by (endpoint)", "legendFormat": "{{endpoint}}", "refId": "A" }],
      "title": "Requests by Endpoint",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "none" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 10 },
      "id": 203,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [{ "expr": "sum(rate(nginx_connections_active[5m]))", "legendFormat": "Active nginx Connections", "refId": "A" }],
      "title": "Active nginx Connections",
      "type": "stat"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 }, "id": 30, "panels": [], "title": "Errors", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 19 },
      "id": 204,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [{
        "expr": "100 * sum(rate(rakuten_http_requests_total{http_status=~'5..'}[5m])) / sum(rate(rakuten_http_requests_total[5m]))",
        "legendFormat": "5xx rate %", "refId": "A"
      }],
      "title": "Error Rate (%)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 1 }, { "color": "red", "value": 10 }] },
          "unit": "short"
        }, "overrides": []
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 205,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["sum"] }, "textMode": "auto" },
      "targets": [{ "expr": "sum(increase(rakuten_auth_failures_total[5m]))", "legendFormat": "Auth Failures", "refId": "A" }],
      "title": "Auth Failures (401)",
      "type": "stat"
    },

    { "collapsed": false, "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 }, "id": 40, "panels": [], "title": "Latency", "type": "row" },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 28 },
      "id": 206,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(rakuten_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(rakuten_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(rakuten_http_request_duration_seconds_bucket[5m])) by (le))", "legendFormat": "P99", "refId": "C" }
      ],
      "title": "Latency P50 / P95 / P99",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 28 },
      "id": 207,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(rakuten_http_request_duration_seconds_bucket{endpoint='/predict'}[5m])) by (le))",
        "legendFormat": "Inference P95", "refId": "A"
      }],
      "title": "Inference-only Latency P95",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "spectrum" }, "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 28 },
      "id": 208,
      "options": { "calculate": false, "cellGap": 1, "color": { "mode": "spectrum", "scheme": "Oranges" }, "tooltip": { "mode": "single" }, "yAxis": { "unit": "s" } },
      "targets": [{
        "expr": "sum(rate(rakuten_http_request_duration_seconds_bucket[5m])) by (le)",
        "legendFormat": "{{le}}", "refId": "A", "format": "heatmap"
      }],
      "title": "Latency Heatmap",
      "type": "heatmap"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 },
      "id": 20,
      "panels": [],
      "title": "ML Model Performance (BentoML)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "id": 1,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(rate(rakuten_predictions_total[5m])) by (predicted_class)", "legendFormat": "Class {{predicted_class}}", "refId": "A" }
      ],
      "title": "Predictions per Class (rate 5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 37 },
      "id": 2,
      "options": { "legend": { "calcs": ["sum"], "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "sum(rate(rakuten_predictions_total[5m]))", "legendFormat": "Total Predictions/s", "refId": "A" }
      ],
      "title": "Total Prediction Rate (5m)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "percentunit" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 45 },
      "id": 3,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(rakuten_prediction_confidence_bucket[5m])) by (le))", "legendFormat": "p50 Confidence", "refId": "A" },
        { "expr": "histogram_quantile(0.90, sum(rate(rakuten_prediction_confidence_bucket[5m])) by (le))", "legendFormat": "p90 Confidence", "refId": "B" }
      ],
      "title": "Prediction Confidence Percentiles",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 45 },
      "id": 4,
      "options": { "legend": { "calcs": ["mean"], "displayMode": "list", "placement": "bottom" } },
      "targets": [{ "expr": "histogram_quantile(0.50, sum(rate(rakuten_batch_size_bucket[5m])) by (le))", "legendFormat": "p50 Batch Size", "refId": "A" }],
      "title": "Batch Size Percentiles",
      "type": "timeseries"
    },

    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "gray", "text": "NOT READY" },
                "1": { "color": "green", "text": "READY" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 53 },
      "id": 5,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "targets": [
        { "expr": "max(rakuten_model_ready)", "refId": "A" }
      ],
      "title": "Model Ready",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            {
              "options": {
                "0": { "color": "green", "text": "READY" },
                "1": { "color": "red", "text": "NOT READY" }
              },
              "type": "value"
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 53 },
      "id": 6,
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name" },
      "targets": [
        { "expr": "1 - max(rakuten_model_ready)", "refId": "A" }
      ],
      "title": "Model Not Ready",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 57 },
      "id": 60,
      "panels": [],
      "title": "Input Text Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 58 },
      "id": 100,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(rakuten_text_length_chars_bucket[5m])) by (le))", "legendFormat": "P50 Length (chars)", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(rakuten_text_length_chars_bucket[5m])) by (le))", "legendFormat": "P95 Length (chars)", "refId": "B" }
      ],
      "title": "Input Text Length (P50 / P95)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "spectrum" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 66 },
      "id": 101,
      "options": { "calculate": false, "cellGap": 1, "color": { "mode": "spectrum", "scheme": "Oranges" }, "tooltip": { "mode": "single" }, "yAxis": { "unit": "short" } },
      "targets": [{ "expr": "sum(rate(rakuten_text_length_chars_bucket[5m])) by (le)", "legendFormat": "{{le}}", "refId": "A", "format": "heatmap" }],
      "title": "Text Length Distribution (Heatmap)",
      "type": "heatmap"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 66 },
      "id": 102,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [{ "expr": "sum(rate(rakuten_text_length_chars_bucket[5m])) by (le)", "legendFormat": "le={{le}}", "refId": "A" }],
      "title": "Text Length Buckets (counts per bucket)",
      "type": "timeseries"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["mlops"],
  "templating": {
    "list": [
      { "current": { "selected": true, "text": "Prometheus", "value": "Prometheus" }, "hide": 0, "name": "datasource", "query": "prometheus", "refresh": 1, "type": "datasource" }
    ]
  },
  "time": { "from": "now-30m", "to": "now" },
  "title": "Rakuten ML Service",
  "uid": "rakuten-ml-service",
  "version": 10
}
